# ============================================================
# Copia este fichero a .env y rellena tus valores
# cp .env.example .env
# ============================================================

# Autenticación — elige una opción:
#
# Opción A: API key (console.anthropic.com → API Keys)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Opción B: dejar vacío → Claude Code pedirá login OAuth al arrancar
# Las credenciales se guardarán en data/home/.claude/ y no volverá a pedir login

# AWS — perfil de ~/.aws/credentials a usar
AWS_PROFILE=default

# MCPs opcionales — déjalos vacíos si no los usas
GITHUB_TOKEN=

# ============================================================
# Modelos por comando de entrada
# ============================================================
ROLE_CHAT=claude-haiku-4-5-20251001
ROLE_RUN=claude-sonnet-5
ROLE_ORCH=claude-opus-4-8

# ============================================================
# Modelos de sub-agentes (usados por el orquestador en Agent())
# ============================================================

# Track de desarrollo
ROLE_SCOUT=claude-haiku-4-5-20251001
ROLE_ARCHITECT=claude-sonnet-5
ROLE_IMPLEMENTER=claude-sonnet-5
ROLE_TESTER=claude-sonnet-5
ROLE_REVIEWER=claude-sonnet-5
ROLE_FIXER=claude-sonnet-5

# Track de documentación
ROLE_DOCUMENTER=claude-sonnet-5

# Track de datos
ROLE_ANALYST=claude-sonnet-5
ROLE_REPORTER=claude-haiku-4-5-20251001

# Track de infraestructura
ROLE_INFRA=claude-sonnet-5
